@echo off











setlocal EnableExtensions EnableDelayedExpansion











cd /d "%~dp0"











title Bali Crypto Command V012J - Bali Themed Starter











set "LAUNCHER_DIR=%CD%"











set "BOOT_REPORT=%LAUNCHER_DIR%\BALI_VISIBLE_BOOT_REPORT_V012J.txt"











set "PYTHONNOUSERSITE=1"











set "PYTHONDONTWRITEBYTECODE=1"











(











  echo BALI ROCKET CRYPTO COMMAND - QUIET STARTUP REPORT V012J











  echo Generated: %DATE% %TIME%











  echo Launcher folder: %LAUNCHER_DIR%











  echo Mission: STARGATE RIVAL MODE - Bali Rocket is being prepared to compete against the Stargate machine.











  echo Update active: V012J Arena marker and local-only two-CPU bridge prep, autopilot, Bali-themed starter, and safety root guard.











  echo Fix active: visible report first, root finder active, Python 3.13 shield active.











  echo One-click update: V012J manifest-aware updater installed after this patch is applied.











  echo Safety: live orders OFF, champion lock LOCKED, no API keys.











  echo.











) > "%BOOT_REPORT%"























call :find_app_root











if not defined APP_ROOT goto :no_app_root























cd /d "%APP_ROOT%"











if not exist logs mkdir logs











set "REPORT=%APP_ROOT%\logs\BALI_VISIBLE_STARTUP_REPORT_V012J.txt"











set "LAST=%APP_ROOT%\logs\LAST_STARTUP_REPORT.txt"











(











  echo BALI ROCKET CRYPTO COMMAND - QUIET STARTUP REPORT V012J











  echo Generated: %DATE% %TIME%











  echo Launcher folder: %LAUNCHER_DIR%











  echo App folder: %APP_ROOT%











  echo Mission: STARGATE RIVAL MODE - Bali Rocket is being prepared to compete against the Stargate machine.











  echo Update active: V012J Arena marker and local-only two-CPU bridge prep, autopilot, Bali-themed starter, and safety root guard.











  echo Fix active: app.py root found before Python compile/run.











  echo Report mode: quiet startup; only final report opens after exit or immediate report opens on error.











  echo Python shield: Python 3.13 is skipped. Preferred order: Python 3.10, 3.11, then 3.12.











  echo Speed lane: use BALI_SPEED_LANE_UPDATE.bat from the launcher folder for future patch zips.











  echo Health check: use BALI_ROCKET_HEALTH_CHECK.bat or BALI_FAST_STATUS_PACK.bat for diagnostics.











  echo Bali themed desktop icon: run BALI_CREATE_FOREVER_DESKTOP_ICON.bat once, then use Bali Forever Starter on Desktop.











  echo Safety: live orders OFF, champion lock LOCKED, no API keys.











  echo.











) > "%REPORT%"























if exist __pycache__ (











  echo Cleaning old Python cache folder: __pycache__ >> "%REPORT%"











  rmdir /s /q __pycache__ >> "%REPORT%" 2>&1











)























call :find_python











if not defined PY_EXE goto :no_python























"%PY_EXE%" -m py_compile "%APP_ROOT%\app.py" >> "%REPORT%" 2>&1











if errorlevel 1 goto :bad_app























(











  echo.











  echo RESULT: READY











  echo Python selected: %PY_EXE%











  "%PY_EXE%" --version











  echo Syntax check: PASS











  echo Dashboard: http://127.0.0.1:9061











  echo Phone mode: use ROCKET_CRYPTO_COMMAND_START_PHONE_LAN_EXPERIMENTAL.bat











  echo Rival marker: Bali-themed challenger versus Stargate machine.











  echo V012J marker: Game Arena foundation with SIM-only Bali vs Stargate scoreboard is installed.











  echo Bali themed icon: Bali Forever Starter desktop shortcut supported.











  echo Safety: live orders OFF, champion lock LOCKED, no API keys.











  echo.











  echo Starting dashboard now. Startup report is saved quietly; final report opens only after exit or if an error occurs.











) >> "%REPORT%" 2>&1











copy "%REPORT%" "%LAST%" >nul 2>nul























if exist "%LAUNCHER_DIR%\logs" (











  copy "%REPORT%" "%LAUNCHER_DIR%\logs\LAST_STARTUP_REPORT.txt" >nul 2>nul











)























echo.
echo Bali Forever Starter V012J ready. Important-only startup report saved quietly.
echo Dashboard opening at http://127.0.0.1:9061
timeout /t 1 /nobreak >nul 2>nul











if exist "%LAUNCHER_DIR%\tools\BALI_CLOSE_DASHBOARD_PORT_V012J.ps1" (
  powershell -NoProfile -ExecutionPolicy Bypass -File "%LAUNCHER_DIR%\tools\BALI_CLOSE_DASHBOARD_PORT_V012J.ps1" -Root "%LAUNCHER_DIR%" -Report "%LAUNCHER_DIR%\logs\BALI_CLOSE_DASHBOARD_PORT_REPORT_V012J.txt" -Port 9061 -Force 1 >> "%REPORT%" 2>&1
  timeout /t 1 /nobreak >nul 2>nul
)

start "" "http://127.0.0.1:9061"











"%PY_EXE%" "%APP_ROOT%\app.py" --host 127.0.0.1 --port 9061











set "RC=%ERRORLEVEL%"











(











  echo.











  echo App exited with code %RC%











  echo Final report generated: %DATE% %TIME%











) >> "%REPORT%"











copy "%REPORT%" "%LAST%" >nul 2>nul











start "" notepad "%REPORT%"











pause











exit /b %RC%























:find_app_root











set "APP_ROOT="











echo === App root scan === >> "%BOOT_REPORT%"











if exist "%LAUNCHER_DIR%\app.py" (











  set "APP_ROOT=%LAUNCHER_DIR%"











  echo ACCEPTED app root: %LAUNCHER_DIR% >> "%BOOT_REPORT%"











  exit /b 0











)











for %%D in ("bali_rocket_crypto_command_v011b" "bali_rocket_crypto_command_v011c" "bali_rocket_crypto_command_v011d" "bali_rocket_crypto_command_v011e" "bali_rocket_crypto_command_v011f" "bali_rocket_crypto_command_v011h" "bali_rocket_crypto_command_v011i" "bali_rocket_crypto_command") do (











  if not defined APP_ROOT if exist "%LAUNCHER_DIR%\%%~D\app.py" (











    set "APP_ROOT=%LAUNCHER_DIR%\%%~D"











    echo ACCEPTED app root: %LAUNCHER_DIR%\%%~D >> "%BOOT_REPORT%"











  )











)











if defined APP_ROOT exit /b 0











for /d %%D in ("%LAUNCHER_DIR%\bali_rocket_crypto_command*") do (











  if not defined APP_ROOT if exist "%%~fD\app.py" (











    set "APP_ROOT=%%~fD"











    echo ACCEPTED app root: %%~fD >> "%BOOT_REPORT%"











  )











)











if defined APP_ROOT exit /b 0











for /d %%D in ("%LAUNCHER_DIR%\*") do (











  if not defined APP_ROOT if exist "%%~fD\app.py" (











    set "APP_ROOT=%%~fD"











    echo ACCEPTED app root: %%~fD >> "%BOOT_REPORT%"











  )











)











if defined APP_ROOT exit /b 0











exit /b 1























:find_python











set "PY_EXE="











echo === Candidate scan === >> "%REPORT%"























if defined BALI_PYTHON_EXE (











  call :try_candidate "%BALI_PYTHON_EXE%" "BALI_PYTHON_EXE override"











  if defined PY_EXE exit /b 0











)























call :try_candidate "%LOCALAPPDATA%\Programs\Python\Python310\python.exe" "direct local Python 3.10"











if defined PY_EXE exit /b 0











call :try_candidate "%LOCALAPPDATA%\Programs\Python\Python311\python.exe" "direct local Python 3.11"











if defined PY_EXE exit /b 0











call :try_candidate "%LOCALAPPDATA%\Programs\Python\Python312\python.exe" "direct local Python 3.12"











if defined PY_EXE exit /b 0











call :try_candidate "%ProgramFiles%\Python310\python.exe" "Program Files Python 3.10"











if defined PY_EXE exit /b 0











call :try_candidate "%ProgramFiles%\Python311\python.exe" "Program Files Python 3.11"











if defined PY_EXE exit /b 0











call :try_candidate "%ProgramFiles%\Python312\python.exe" "Program Files Python 3.12"











if defined PY_EXE exit /b 0























call :log_skipped_bad_python "%LOCALAPPDATA%\Programs\Python\Python313\python.exe"











call :log_skipped_bad_python "%ProgramFiles%\Python313\python.exe"























where py >nul 2>nul











if not errorlevel 1 (











  for %%V in (3.10 3.11 3.12) do (











    py -%%V -c "import sys; print(sys.executable)" > "%APP_ROOT%\logs\_py_candidate.txt" 2>> "%REPORT%"











    if not errorlevel 1 (











      set /p CAND=<"%APP_ROOT%\logs\_py_candidate.txt"











      call :try_candidate "!CAND!" "py launcher %%V"











      if defined PY_EXE (











        del "%APP_ROOT%\logs\_py_candidate.txt" >nul 2>nul











        exit /b 0











      )











    )











  )











)























where python >nul 2>nul











if not errorlevel 1 (











  for /f "delims=" %%P in ('where python') do (











    call :try_candidate "%%P" "PATH python"











    if defined PY_EXE exit /b 0











  )











)























where python3 >nul 2>nul











if not errorlevel 1 (











  for /f "delims=" %%P in ('where python3') do (











    call :try_candidate "%%P" "PATH python3"











    if defined PY_EXE exit /b 0











  )











)























exit /b 1























:try_candidate











set "CAND=%~1"











set "LABEL=%~2"











if not defined CAND exit /b 1











if not exist "%CAND%" (











  echo SKIP missing: %LABEL% - %CAND% >> "%REPORT%"











  exit /b 1











)











echo Checking: %LABEL% - %CAND% >> "%REPORT%"























echo %CAND% | findstr /I "Python313" >nul 2>nul











if not errorlevel 1 (











  echo SKIP bad python shield: Python 3.13 path rejected - %CAND% >> "%REPORT%"











  exit /b 1











)























"%CAND%" -c "import sys, pathlib, http.server, threading, urllib.request; print('probe_version=' + sys.version.split()[0]); raise SystemExit(0 if sys.version_info >= (3,10) and sys.version_info < (3,13) else 8)" >> "%REPORT%" 2>&1











if errorlevel 1 (











  echo SKIP failed version/import probe: %CAND% >> "%REPORT%"











  exit /b 1











)























"%CAND%" -m py_compile "%APP_ROOT%\app.py" >> "%REPORT%" 2>&1











if errorlevel 1 (











  echo SKIP app compile failed with: %CAND% >> "%REPORT%"











  exit /b 1











)























set "PY_EXE=%CAND%"











echo ACCEPTED: %LABEL% - %PY_EXE% >> "%REPORT%"











exit /b 0























:log_skipped_bad_python











set "BADPY=%~1"











if exist "%BADPY%" echo FOUND BUT SKIPPED bad Python 3.13: %BADPY% >> "%REPORT%"











exit /b 0























:no_app_root











(











  echo.











  echo RESULT: APP ROOT NOT FOUND











  echo This launcher could not find app.py in the launcher folder or one folder below it.











  echo Put this BAT in either the full build parent folder or the bali_rocket_crypto_command folder.











  echo For your current build, the expected app folder is usually bali_rocket_crypto_command_v011b.











) >> "%BOOT_REPORT%"











echo.











type "%BOOT_REPORT%"











start "" notepad "%BOOT_REPORT%"











pause











exit /b 2























:no_python











(











  echo.











  echo RESULT: GOOD PYTHON NOT FOUND











  echo App root WAS found: %APP_ROOT%











  echo Python 3.13 was intentionally skipped because it caused crash code -1073741521.











  echo Install or repair Python 3.10, 3.11, or 3.12, then run this again.











  echo Best target for your machine is usually Python 3.10 or 3.11.











) >> "%REPORT%"











copy "%REPORT%" "%LAST%" >nul 2>nul











echo.











type "%REPORT%"











start "" notepad "%REPORT%"











pause











exit /b 1























:bad_app











(











  echo.











  echo RESULT: APP PYTHON SYNTAX CHECK FAILED











  echo App root: %APP_ROOT%











  echo This is a build problem, not your computer. Paste this report back into ChatGPT.











) >> "%REPORT%"











copy "%REPORT%" "%LAST%" >nul 2>nul











echo.











type "%REPORT%"











start "" notepad "%REPORT%"











pause











exit /b 3











