@echo off











setlocal EnableExtensions EnableDelayedExpansion











cd /d "%~dp0"











title Bali Crypto Command - Health Check V012J











set "ROOT=%CD%"











set "LOGDIR=%ROOT%\logs"











if not exist "%LOGDIR%" mkdir "%LOGDIR%"











set "REPORT=%LOGDIR%\BALI_ROCKET_HEALTH_CHECK_REPORT_V012J.txt"











(











  echo BALI ROCKET CRYPTO COMMAND - HEALTH CHECK REPORT V012J











  echo Generated: %DATE% %TIME%











  echo Root folder: %ROOT%











  echo Mission: STARGATE RIVAL MODE - verify the challenger machine without launching trades.











  echo Purpose: no-launch diagnostic for app root, Python, syntax, updater, speed lane, icon assets, and port visibility.











  echo Speed lane: use BALI_SPEED_LANE_UPDATE.bat for future patch ZIPs.


  echo Fast status: use BALI_FAST_STATUS_PACK.bat before asking ChatGPT for the next patch.


  echo Safety: live orders OFF, champion lock LOCKED, no API keys.











  echo.











) > "%REPORT%"























call :find_app_root











if not defined APP_ROOT goto :no_app











(











  echo App root: %APP_ROOT%











  echo app.py: FOUND











) >> "%REPORT%"























call :find_python











if not defined PY_EXE goto :no_python























"%PY_EXE%" -m py_compile "%APP_ROOT%\app.py" >> "%REPORT%" 2>&1











if errorlevel 1 goto :bad_app























(











  echo.











  echo === Updater check ===











) >> "%REPORT%"











if exist "%ROOT%\BALI_ONE_CLICK_UPDATE.bat" (echo BALI_ONE_CLICK_UPDATE.bat: FOUND >> "%REPORT%") else (echo BALI_ONE_CLICK_UPDATE.bat: MISSING >> "%REPORT%")











if exist "%ROOT%\tools\BALI_ONE_CLICK_UPDATE_ENGINE_V012J.ps1" (echo V012J update engine: FOUND >> "%REPORT%") else (echo V012J update engine: MISSING >> "%REPORT%")


if exist "%ROOT%\BALI_SPEED_LANE_UPDATE.bat" (echo Speed lane updater: FOUND >> "%REPORT%") else (echo Speed lane updater: MISSING >> "%REPORT%")


if exist "%ROOT%\BALI_FAST_STATUS_PACK.bat" (echo Fast status pack: FOUND >> "%REPORT%") else (echo Fast status pack: MISSING >> "%REPORT%")











if exist "%ROOT%\BALI_PATCH_MANIFEST.txt" (echo Root manifest: FOUND >> "%REPORT%") else (echo Root manifest: MISSING >> "%REPORT%")























(











  echo.











  echo === Bali themed desktop starter icon check ===





) >> "%REPORT%"





if exist "%ROOT%\assets\BALI_FOREVER_THEME_ICON_V012J.ico" (





  echo Bali themed icon file V012J: FOUND >> "%REPORT%"





) else if exist "%ROOT%\assets\BALI_ROCKET_FOREVER_ICON_V011J.ico" (





  echo Compatibility icon alias: FOUND >> "%REPORT%"





) else (





  echo Bali themed icon file: MISSING >> "%REPORT%"





)





if exist "%ROOT%\BALI_CREATE_FOREVER_DESKTOP_ICON.bat" (echo Icon creator: FOUND >> "%REPORT%") else (echo Icon creator: MISSING >> "%REPORT%")





if exist "%USERPROFILE%\Desktop\Bali Forever Starter.lnk" (





  echo Desktop shortcut: FOUND - Bali Forever Starter >> "%REPORT%"





) else (





  echo Desktop shortcut: NOT CREATED YET - run BALI_CREATE_FOREVER_DESKTOP_ICON.bat >> "%REPORT%"





)





if exist "%USERPROFILE%\Desktop\Bali Rocket Forever Starter.lnk" echo Old rocket-branded shortcut: STILL PRESENT - run BALI_CREATE_FOREVER_DESKTOP_ICON.bat to remove it >> "%REPORT%"











(





  echo === Port 9061 visibility check ===











) >> "%REPORT%"











netstat -ano | findstr /R /C:":9061" >> "%REPORT%" 2>&1











if errorlevel 1 echo Port 9061: no active listener right now. This is OK if the dashboard is not running. >> "%REPORT%"























(











  echo.











  echo RESULT: HEALTH PASS











  echo Python selected: %PY_EXE%











  "%PY_EXE%" --version











  echo Syntax check: PASS











  echo Dashboard target: http://127.0.0.1:9061











  echo Phone LAN target: http://YOUR-PC-LAN-IP:9061 when phone launcher is running.











  echo Rival marker: Bali-themed challenger versus Stargate machine.











  echo Speed lane: use BALI_SPEED_LANE_UPDATE.bat for future patch ZIPs.


  echo Fast status: use BALI_FAST_STATUS_PACK.bat before asking ChatGPT for the next patch.


  echo Safety: live orders OFF, champion lock LOCKED, no API keys.











) >> "%REPORT%" 2>&1























if exist "%APP_ROOT%\logs" copy "%REPORT%" "%APP_ROOT%\logs\LAST_HEALTH_CHECK_REPORT.txt" >nul 2>nul











copy "%REPORT%" "%LOGDIR%\LAST_HEALTH_CHECK_REPORT.txt" >nul 2>nul























echo.











type "%REPORT%"











start "" notepad "%REPORT%"











pause











exit /b 0























:find_app_root











set "APP_ROOT="











echo === App root scan === >> "%REPORT%"











if exist "%ROOT%\app.py" (











  set "APP_ROOT=%ROOT%"











  echo ACCEPTED app root: %ROOT% >> "%REPORT%"











  exit /b 0











)











for %%D in ("bali_rocket_crypto_command_v011b" "bali_rocket_crypto_command_v011c" "bali_rocket_crypto_command_v011d" "bali_rocket_crypto_command_v011e" "bali_rocket_crypto_command_v011f" "bali_rocket_crypto_command_v011h" "bali_rocket_crypto_command_v011i" "bali_rocket_crypto_command_v011j" "bali_rocket_crypto_command_v011k" "bali_rocket_crypto_command") do (











  if not defined APP_ROOT if exist "%ROOT%\%%~D\app.py" (











    set "APP_ROOT=%ROOT%\%%~D"











    echo ACCEPTED app root: %ROOT%\%%~D >> "%REPORT%"











  )











)











if defined APP_ROOT exit /b 0











for /d %%D in ("%ROOT%\bali_rocket_crypto_command*") do (











  if not defined APP_ROOT if exist "%%~fD\app.py" (











    set "APP_ROOT=%%~fD"











    echo ACCEPTED app root: %%~fD >> "%REPORT%"











  )











)











if defined APP_ROOT exit /b 0











for /d %%D in ("%ROOT%\*") do (











  if not defined APP_ROOT if exist "%%~fD\app.py" (











    set "APP_ROOT=%%~fD"











    echo ACCEPTED app root: %%~fD >> "%REPORT%"











  )











)











exit /b 0























:find_python











set "PY_EXE="











echo. >> "%REPORT%"











echo === Python candidate scan === >> "%REPORT%"











call :try_candidate "%LOCALAPPDATA%\Programs\Python\Python310\python.exe" "direct local Python 3.10"











if defined PY_EXE exit /b 0











call :try_candidate "%LOCALAPPDATA%\Programs\Python\Python311\python.exe" "direct local Python 3.11"











if defined PY_EXE exit /b 0











call :try_candidate "%LOCALAPPDATA%\Programs\Python\Python312\python.exe" "direct local Python 3.12"











if defined PY_EXE exit /b 0











call :try_candidate "%ProgramFiles%\Python310\python.exe" "Program Files Python 3.10"











if defined PY_EXE exit /b 0











call :try_candidate "%ProgramFiles%\Python311\python.exe" "Program Files Python 3.11"











if defined PY_EXE exit /b 0











call :try_candidate "%ProgramFiles%\Python312\python.exe" "Program Files Python 3.12"











if defined PY_EXE exit /b 0











if exist "%LOCALAPPDATA%\Programs\Python\Python313\python.exe" echo FOUND BUT SKIPPED bad Python 3.13: %LOCALAPPDATA%\Programs\Python\Python313\python.exe >> "%REPORT%"











if exist "%ProgramFiles%\Python313\python.exe" echo FOUND BUT SKIPPED bad Python 3.13: %ProgramFiles%\Python313\python.exe >> "%REPORT%"











exit /b 1























:try_candidate











set "CAND=%~1"











set "LABEL=%~2"











if not exist "%CAND%" (











  echo SKIP missing: %LABEL% - %CAND% >> "%REPORT%"











  exit /b 1











)











echo Checking: %LABEL% - %CAND% >> "%REPORT%"











echo %CAND% | findstr /I "Python313" >nul 2>nul











if not errorlevel 1 (











  echo SKIP bad python shield: %CAND% >> "%REPORT%"











  exit /b 1











)











"%CAND%" -c "import sys; print('probe_version=' + sys.version.split()[0]); raise SystemExit(0 if sys.version_info >= (3,10) and sys.version_info < (3,13) else 8)" >> "%REPORT%" 2>&1











if errorlevel 1 (











  echo SKIP failed version probe: %CAND% >> "%REPORT%"











  exit /b 1











)











set "PY_EXE=%CAND%"











echo ACCEPTED: %LABEL% - %PY_EXE% >> "%REPORT%"











exit /b 0























:no_app











(











  echo.











  echo RESULT: HEALTH FAIL - APP ROOT NOT FOUND











  echo Could not find app.py from root folder: %ROOT%











) >> "%REPORT%"











type "%REPORT%"











start "" notepad "%REPORT%"











pause











exit /b 2























:no_python











(











  echo.











  echo RESULT: HEALTH FAIL - GOOD PYTHON NOT FOUND











  echo Python 3.13 remains blocked. Use Python 3.10, 3.11, or 3.12.











) >> "%REPORT%"











type "%REPORT%"











start "" notepad "%REPORT%"











pause











exit /b 3























:bad_app











(











  echo.











  echo RESULT: HEALTH FAIL - APP PYTHON SYNTAX CHECK FAILED











  echo App root: %APP_ROOT%











  echo Paste this report back into ChatGPT.











) >> "%REPORT%"











type "%REPORT%"











start "" notepad "%REPORT%"











pause











exit /b 4











